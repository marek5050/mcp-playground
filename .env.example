# Public URL where this server is reachable (no trailing slash).
# Local dev: http://localhost:8080 — Production: https://playground.mcpbuilders.dev
BASE_URL=http://localhost:8080

# Cloud Run injects PORT automatically; default 8080 for local dev.
PORT=8080

# mixed    -> 3 anonymous read-only tools + gated per-user tools (default)
# required -> every request needs Google sign-in (Claude auto-triggers OAuth on connect)
# off      -> no auth wiring at all (local dataset hacking)
AUTH_MODE=mixed

# Google OAuth web client from the mcp-builders GCP project
# (GCP Console -> APIs & Services -> Credentials). The client must list
# {BASE_URL}/auth/callback as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx
